#!/bin/bash
set -e

INSTALL_DIR="/opt/polyglot-ai"
VENV_DIR="$INSTALL_DIR/venv"
WHEELS_DIR="$INSTALL_DIR/wheels"

# Create virtual environment
python3 -m venv "$VENV_DIR"

# Install from bundled wheels first so the package works offline
# (corporate proxy, fresh-from-iso install, flight Wi-Fi, etc.).
# ``--no-index`` forbids contacting PyPI and ``--find-links`` makes
# the resolver use the bundled wheels exclusively. Falls back to a
# regular online install if the bundle is missing or incomplete —
# that way a misconfigured CI can never produce an unusable .deb.
if [ -d "$WHEELS_DIR" ] && [ -n "$(ls -A "$WHEELS_DIR" 2>/dev/null)" ]; then
    echo "Installing Polyglot AI from bundled wheels (offline)…"
    "$VENV_DIR/bin/pip" install --no-index --find-links "$WHEELS_DIR" \
        "$INSTALL_DIR"/*.whl || {
        echo "Offline install failed; retrying with online resolver…"
        "$VENV_DIR/bin/pip" install --upgrade pip
        "$VENV_DIR/bin/pip" install "$INSTALL_DIR"/*.whl
    }
else
    echo "No bundled wheels found; falling back to online install (needs network)…"
    "$VENV_DIR/bin/pip" install --upgrade pip
    "$VENV_DIR/bin/pip" install "$INSTALL_DIR"/*.whl
fi

# Create symlink
ln -sf "$VENV_DIR/bin/polyglot-ai" /usr/local/bin/polyglot-ai

# Refresh desktop and icon caches so the launcher entry and icon
# appear in the user's app menu immediately, not after the next
# login. dpkg triggers usually handle this on Debian/Ubuntu, but
# being explicit is belt-and-braces — it matters on minimal
# installs (Docker images, chroots, server distros) where the
# triggering path might not be wired up. Both tools no-op when
# the optional package providing them isn't installed.
if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database -q /usr/share/applications || true
fi
if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    # ``-f`` forces a refresh even when mtime didn't change;
    # ``-t`` prevents a hard fail if the index file is missing.
    gtk-update-icon-cache -f -t /usr/share/icons/hicolor || true
fi

# Hint that Arduino uploads need the user to be in the dialout
# group. Posix-portable ``id -nG`` since ``getent group dialout``
# might not be installed on minimal images.
if ! id -nG "$SUDO_USER" 2>/dev/null | grep -qw dialout; then
    if [ -n "$SUDO_USER" ]; then
        echo ""
        echo "Heads up: to use the Arduino upload feature you'll need"
        echo "to be in the 'dialout' group. Run:"
        echo "    sudo usermod -aG dialout $SUDO_USER"
        echo "and log out / back in."
    fi
fi

echo "Polyglot AI installed successfully."
echo "Run 'polyglot-ai' to start, or find it in your application menu."
